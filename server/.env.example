# 生产部署时，scripts/deploy.sh 会自动生成 server/.env
# 本文件仅用于手动开发或自定义参考

# 服务器配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 数据库配置
DATABASE_PATH=./data/mev.db

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS配置
ALLOWED_ORIGINS=https://your-domain.com:8443

# 写接口允许的角色（默认 admin）
WRITE_API_ALLOWED_ROLES=admin

# 生产环境建议关闭自动同步
SYNCHRONIZE_DB=0

# 日志级别
LOG_LEVEL=info
